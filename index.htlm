<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Mi Balance · Proteínas y calorías</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --paper:#F2F4EC; --card:#FFFFFF; --ink:#1F2A1D; --muted:#6A7362;
  --line:#DCE0D2; --prot:#2F6B45; --prot-soft:#E3EEE6;
  --kcal:#A93B4F; --kcal-soft:#F4E4E7; --ok:#2F6B45; --warn:#A93B4F;
  --radius:14px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{-webkit-text-size-adjust:100%}
body{
  font-family:'Instrument Sans',system-ui,sans-serif; background:var(--paper); color:var(--ink);
  min-height:100dvh; padding-bottom:84px; font-size:16px; line-height:1.45;
}
.wrap{max-width:520px;margin:0 auto;padding:18px 16px 8px}
header.app h1{
  font-family:'Fraunces',serif; font-weight:700; font-size:1.55rem; letter-spacing:-.01em;
}
header.app .fecha{color:var(--muted);font-size:.9rem;margin-top:2px;text-transform:capitalize}

/* ------- balance del día (firma visual) ------- */
.balance{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:16px;margin-top:14px}
.metro{margin-bottom:14px}
.metro:last-child{margin-bottom:0}
.metro .fila{display:flex;justify-content:space-between;align-items:baseline}
.metro .nombre{font-size:.8rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--muted)}
.metro .num{font-family:'Fraunces',serif;font-weight:600;font-size:1.5rem;font-variant-numeric:tabular-nums}
.metro .num small{font-size:.85rem;color:var(--muted);font-family:'Instrument Sans',sans-serif;font-weight:500}
.barra{height:10px;border-radius:6px;background:#EDEFE6;overflow:hidden;margin-top:6px;position:relative}
.barra .fill{height:100%;border-radius:6px;transition:width .4s ease}
.barra .fill.p{background:var(--prot)} .barra .fill.k{background:var(--kcal)}
.barra .fill.over{background:repeating-linear-gradient(45deg,var(--warn),var(--warn) 6px,#c76a7a 6px,#c76a7a 12px)}
.diff{font-family:'Fraunces',serif;font-style:italic;font-size:1rem;margin-top:5px}
.diff.ok{color:var(--ok)} .diff.over{color:var(--warn)} .diff.neutro{color:var(--muted)}
.sinmeta{color:var(--muted);font-size:.9rem;margin-top:4px}
.sinmeta a{color:var(--prot);font-weight:600;cursor:pointer;text-decoration:underline}

/* ------- botones de registro ------- */
.acciones{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px}
.acciones button{
  border:1px solid var(--line);background:var(--card);border-radius:var(--radius);
  padding:12px 6px;font-family:inherit;font-size:.85rem;font-weight:600;color:var(--ink);cursor:pointer
}
.acciones button .ic{display:block;font-size:1.15rem;margin-bottom:3px}
.acciones button:active{background:var(--prot-soft)}

/* ------- lista de comidas del día ------- */
.seccion-titulo{font-size:.8rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);margin:20px 0 8px}
.item{
  background:var(--card);border:1px solid var(--line);border-radius:var(--radius);
  padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;gap:10px
}
.item .info{min-width:0}
.item .nombre{font-weight:600;font-size:.95rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item .hora{color:var(--muted);font-size:.8rem}
.item .macros{text-align:right;flex-shrink:0;font-variant-numeric:tabular-nums;font-size:.9rem}
.item .macros .p{color:var(--prot);font-weight:600}
.item .macros .k{color:var(--kcal);font-weight:600}
.item .ops{display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.item .ops button{border:none;background:none;font-size:1rem;cursor:pointer;color:var(--muted);padding:2px}
.vacio{color:var(--muted);text-align:center;padding:26px 10px;font-size:.95rem}

/* ------- tabs inferiores ------- */
nav.tabs{
  position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--line);
  display:flex;justify-content:space-around;padding:6px 0 calc(6px + env(safe-area-inset-bottom));z-index:50
}
nav.tabs button{border:none;background:none;font-family:inherit;font-size:.72rem;font-weight:600;color:var(--muted);cursor:pointer;padding:4px 12px}
nav.tabs button .ic{display:block;font-size:1.25rem;margin-bottom:1px}
nav.tabs button.act{color:var(--prot)}

/* ------- modales ------- */
.overlay{position:fixed;inset:0;background:rgba(31,42,29,.45);display:none;align-items:flex-end;justify-content:center;z-index:100}
.overlay.on{display:flex}
.modal{background:var(--card);border-radius:18px 18px 0 0;width:100%;max-width:520px;padding:20px 18px calc(20px + env(safe-area-inset-bottom));max-height:88dvh;overflow-y:auto}
.modal h2{font-family:'Fraunces',serif;font-size:1.25rem;font-weight:700;margin-bottom:12px}
.modal label{display:block;font-size:.82rem;font-weight:600;color:var(--muted);margin:12px 0 4px}
.modal input[type=text],.modal input[type=number],.modal input[type=password],.modal textarea,.modal select{
  width:100%;border:1px solid var(--line);border-radius:10px;padding:11px 12px;font-family:inherit;font-size:1rem;background:#FBFCF8;color:var(--ink)
}
.modal textarea{resize:vertical;min-height:74px}
.fila2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn{width:100%;border:none;border-radius:12px;padding:13px;font-family:inherit;font-size:1rem;font-weight:600;cursor:pointer;margin-top:16px}
.btn.pri{background:var(--prot);color:#fff}
.btn.sec{background:none;border:1px solid var(--line);color:var(--ink);margin-top:8px}
.btn.peligro{background:none;border:1px solid var(--line);color:var(--warn);margin-top:8px}
.btn:disabled{opacity:.5}
.nota{font-size:.82rem;color:var(--muted);margin-top:8px}
.err{color:var(--warn);font-size:.85rem;margin-top:8px;display:none}

/* IA resultado editable */
.ia-item{display:grid;grid-template-columns:1fr 70px 70px 30px;gap:6px;align-items:center;margin-bottom:6px}
.ia-item input{border:1px solid var(--line);border-radius:8px;padding:8px;font-size:.9rem;width:100%;background:#FBFCF8}
.ia-head{display:grid;grid-template-columns:1fr 70px 70px 30px;gap:6px;font-size:.72rem;color:var(--muted);font-weight:600;margin-bottom:4px}
.ia-item button{border:none;background:none;cursor:pointer;color:var(--muted)}

/* frecuentes */
.freq{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;gap:8px}
.freq .add{border:none;background:var(--prot);color:#fff;border-radius:10px;width:38px;height:38px;font-size:1.3rem;cursor:pointer;flex-shrink:0}
.freq .del{border:none;background:none;color:var(--muted);cursor:pointer;font-size:1rem;flex-shrink:0}

/* historial */
.dia-hist{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;margin-bottom:8px}
.dia-hist .cab{display:flex;justify-content:space-between;align-items:baseline;cursor:pointer}
.dia-hist .f{font-weight:600;text-transform:capitalize;font-size:.92rem}
.dia-hist .tot{font-variant-numeric:tabular-nums;font-size:.88rem;text-align:right}
.dia-hist .detalle{display:none;margin-top:10px;border-top:1px solid var(--line);padding-top:8px}
.dia-hist.abierto .detalle{display:block}
.dia-hist .detalle .r{display:flex;justify-content:space-between;font-size:.85rem;padding:3px 0;color:var(--muted)}
.chip{display:inline-block;font-size:.72rem;font-weight:600;padding:2px 8px;border-radius:20px;margin-left:6px}
.chip.ok{background:var(--prot-soft);color:var(--prot)}
.chip.over{background:var(--kcal-soft);color:var(--kcal)}

.pantalla{display:none}.pantalla.act{display:block}
h2.pag{font-family:'Fraunces',serif;font-size:1.35rem;font-weight:700;margin-bottom:4px}
.sub{color:var(--muted);font-size:.88rem;margin-bottom:14px}
.spin{display:inline-block;width:16px;height:16px;border:2px solid #fff;border-top-color:transparent;border-radius:50%;animation:g .7s linear infinite;vertical-align:-3px;margin-right:6px}
@keyframes g{to{transform:rotate(360deg)}}
@media (prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
</style>
</head>
<body>

<div class="wrap">

  <!-- ================= HOY ================= -->
  <section id="pant-hoy" class="pantalla act">
    <header class="app">
      <h1>Mi Balance</h1>
      <div class="fecha" id="fechaHoy"></div>
    </header>

    <div class="balance" id="balance"></div>

    <div class="acciones">
      <button onclick="abrirIA(true)"><span class="ic">📷</span>Foto del plato</button>
      <button onclick="abrirIA()"><span class="ic">✨</span>Describir con IA</button>
      <button onclick="verTab('frec')"><span class="ic">⭐</span>Mis frecuentes</button>
      <button onclick="abrirManual()"><span class="ic">✏️</span>Ingreso manual</button>
    </div>

    <div class="seccion-titulo">Lo que comí hoy</div>
    <div id="listaHoy"></div>
  </section>

  <!-- ================= HISTORIAL ================= -->
  <section id="pant-hist" class="pantalla">
    <h2 class="pag">Historial</h2>
    <p class="sub">Toca un día para ver el detalle.</p>
    <div id="listaHist"></div>
  </section>

  <!-- ================= FRECUENTES ================= -->
  <section id="pant-frec" class="pantalla">
    <h2 class="pag">Mis frecuentes</h2>
    <p class="sub">Comidas que repites. El botón + las agrega a hoy con un toque.</p>
    <div id="listaFrec"></div>
    <button class="btn sec" onclick="abrirManual(true)">＋ Crear frecuente nuevo</button>
  </section>

  <!-- ================= AJUSTES ================= -->
  <section id="pant-ajus" class="pantalla">
    <h2 class="pag">Metas y ajustes</h2>
    <div class="balance" style="margin-top:6px">
      <label style="font-size:.82rem;font-weight:600;color:var(--muted)">Meta diaria de calorías (kcal)</label>
      <input type="number" id="metaKcal" inputmode="numeric" style="width:100%;border:1px solid var(--line);border-radius:10px;padding:11px;font-size:1rem;margin-top:4px;background:#FBFCF8">
      <label style="font-size:.82rem;font-weight:600;color:var(--muted);display:block;margin-top:12px">Meta diaria de proteína (g)</label>
      <input type="number" id="metaProt" inputmode="numeric" style="width:100%;border:1px solid var(--line);border-radius:10px;padding:11px;font-size:1rem;margin-top:4px;background:#FBFCF8">
      <button class="btn pri" onclick="guardarMetas()">Guardar metas</button>
      <button class="btn sec" onclick="abrirCalc()">Calcular mis metas (sexo, edad, peso…)</button>
    </div>

    <div class="seccion-titulo">Estimación con IA</div>
    <div class="balance">
      <p class="nota" style="margin-top:0">Para usar "Describir con IA" fuera de Claude, necesitas tu propia API key de Anthropic (console.anthropic.com). Se guarda solo en este navegador, nunca se sube a ningún lado.</p>
      <label style="font-size:.82rem;font-weight:600;color:var(--muted);display:block;margin-top:10px">API key (opcional)</label>
      <input type="password" id="apiKey" placeholder="sk-ant-…" style="width:100%;border:1px solid var(--line);border-radius:10px;padding:11px;font-size:.95rem;margin-top:4px;background:#FBFCF8">
      <button class="btn sec" onclick="guardarKey()">Guardar key</button>
    </div>

    <div class="seccion-titulo">Mis datos</div>
    <div class="balance">
      <button class="btn sec" style="margin-top:0" onclick="exportar()">Descargar respaldo (JSON)</button>
      <label style="font-size:.82rem;font-weight:600;color:var(--muted);display:block;margin-top:12px">Restaurar respaldo</label>
      <input type="file" id="archivoImport" accept=".json" style="margin-top:6px;font-size:.85rem" onchange="importar(this)">
      <button class="btn peligro" onclick="borrarTodo()">Borrar todos los datos</button>
      <p class="nota">Los datos viven solo en este navegador (localStorage). Si borras datos de navegación, se pierden: descarga un respaldo de vez en cuando.</p>
    </div>
  </section>
</div>

<!-- ================= NAV ================= -->
<nav class="tabs">
  <button id="tab-hoy" class="act" onclick="verTab('hoy')"><span class="ic">🍽️</span>Hoy</button>
  <button id="tab-hist" onclick="verTab('hist')"><span class="ic">📅</span>Historial</button>
  <button id="tab-frec" onclick="verTab('frec')"><span class="ic">⭐</span>Frecuentes</button>
  <button id="tab-ajus" onclick="verTab('ajus')"><span class="ic">⚙️</span>Ajustes</button>
</nav>

<!-- ================= MODAL MANUAL ================= -->
<div class="overlay" id="ovManual">
  <div class="modal">
    <h2 id="tituloManual">Ingreso manual</h2>
    <label>Nombre</label>
    <input type="text" id="mNombre" placeholder="Ej: Pechuga de pollo 200 g">
    <div class="fila2">
      <div><label>Proteína (g)</label><input type="number" id="mProt" inputmode="decimal" placeholder="0"></div>
      <div><label>Calorías (kcal)</label><input type="number" id="mKcal" inputmode="decimal" placeholder="0"></div>
    </div>
    <label style="display:flex;align-items:center;gap:8px;margin-top:14px;font-size:.9rem;color:var(--ink);font-weight:500">
      <input type="checkbox" id="mFrec" style="width:18px;height:18px"> Guardar también en frecuentes
    </label>
    <div class="err" id="mErr">Falta el nombre o los valores.</div>
    <button class="btn pri" onclick="guardarManual()">Agregar</button>
    <button class="btn sec" onclick="cerrar('ovManual')">Cancelar</button>
  </div>
</div>

<!-- ================= MODAL IA ================= -->
<div class="overlay" id="ovIA">
  <div class="modal">
    <h2>Estimar con IA</h2>
    <p class="nota" style="margin-top:0">Foto, texto o ambos. La foto sola tiene más margen de error (±30–50%): agregar contexto en texto mejora mucho la estimación. Los valores son editables antes de guardar.</p>
    <input type="file" id="iaFoto" accept="image/*" capture="environment" style="display:none" onchange="fotoElegida(this)">
    <button class="btn sec" style="margin-top:10px" onclick="document.getElementById('iaFoto').click()">📷 Tomar o elegir foto del plato</button>
    <div id="iaPreviewBox" style="display:none;margin-top:10px;position:relative">
      <img id="iaPreview" alt="Foto del plato" style="width:100%;border-radius:12px;border:1px solid var(--line)">
      <button onclick="quitarFoto()" style="position:absolute;top:8px;right:8px;border:none;background:rgba(31,42,29,.7);color:#fff;border-radius:20px;width:30px;height:30px;cursor:pointer;font-size:.95rem">✕</button>
    </div>
    <label>¿Qué comiste? <span style="font-weight:400;text-transform:none">(opcional si hay foto)</span></label>
    <textarea id="iaTexto" placeholder="Ej: un pan con palta y huevo, café con leche descremada, una manzana"></textarea>
    <div class="err" id="iaErr"></div>
    <button class="btn pri" id="iaBtn" onclick="estimarIA()">Estimar</button>
    <div id="iaResultado" style="display:none;margin-top:16px">
      <div class="seccion-titulo" style="margin-top:0">Resultado (edita si es necesario)</div>
      <div class="ia-head"><span>Alimento</span><span>Prot g</span><span>kcal</span><span></span></div>
      <div id="iaItems"></div>
      <button class="btn pri" onclick="guardarIA()">Agregar todo a hoy</button>
    </div>
    <button class="btn sec" onclick="cerrar('ovIA')">Cerrar</button>
  </div>
</div>

<!-- ================= MODAL CALCULADORA ================= -->
<div class="overlay" id="ovCalc">
  <div class="modal">
    <h2>Calcular metas</h2>
    <p class="nota" style="margin-top:0">Fórmula Mifflin-St Jeor. Es un punto de partida con ±10–15% de error, no una indicación médica.</p>
    <div class="fila2">
      <div><label>Sexo</label><select id="cSexo"><option value="f">Femenino</option><option value="m">Masculino</option></select></div>
      <div><label>Edad</label><input type="number" id="cEdad" inputmode="numeric"></div>
    </div>
    <div class="fila2">
      <div><label>Peso (kg)</label><input type="number" id="cPeso" inputmode="decimal"></div>
      <div><label>Altura (cm)</label><input type="number" id="cAlt" inputmode="numeric"></div>
    </div>
    <label>Actividad física</label>
    <select id="cAct">
      <option value="1.2">Sedentaria (escritorio, poco ejercicio)</option>
      <option value="1.375">Ligera (1–3 días/semana)</option>
      <option value="1.55">Moderada (3–5 días/semana)</option>
      <option value="1.725">Alta (6–7 días/semana)</option>
    </select>
    <label>Objetivo</label>
    <select id="cObj">
      <option value="bajar">Bajar grasa (déficit 20%, proteína 1,8 g/kg)</option>
      <option value="mantener">Mantener (proteína 1,4 g/kg)</option>
      <option value="subir">Ganar músculo (superávit 10%, proteína 1,8 g/kg)</option>
    </select>
    <div class="err" id="cErr">Completa todos los campos.</div>
    <button class="btn pri" onclick="calcular()">Calcular y usar como meta</button>
    <button class="btn sec" onclick="cerrar('ovCalc')">Cancelar</button>
  </div>
</div>

<script>
/* ============ almacenamiento ============ */
const K={dias:'mb_dias',metas:'mb_metas',frec:'mb_frec',key:'mb_apikey'};
const get=(k,d)=>{try{return JSON.parse(localStorage.getItem(k))??d}catch(e){return d}};
const set=(k,v)=>localStorage.setItem(k,JSON.stringify(v));
let dias=get(K.dias,{});
let metas=get(K.metas,null);           // {kcal, prot}
let frec=get(K.frec,[]);               // [{id,nombre,prot,kcal}]
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,6);

function hoyKey(){
  const d=new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}
function fechaLarga(key){
  const [y,m,d]=key.split('-').map(Number);
  return new Date(y,m-1,d).toLocaleDateString('es-CL',{weekday:'long',day:'numeric',month:'long'});
}
const n1=x=>Math.round(x*10)/10;

/* ============ tabs ============ */
function verTab(t){
  document.querySelectorAll('.pantalla').forEach(p=>p.classList.remove('act'));
  document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.remove('act'));
  document.getElementById('pant-'+t).classList.add('act');
  document.getElementById('tab-'+t).classList.add('act');
  if(t==='hoy')renderHoy();
  if(t==='hist')renderHist();
  if(t==='frec')renderFrec();
  if(t==='ajus')cargarAjustes();
  window.scrollTo(0,0);
}
function cerrar(id){document.getElementById(id).classList.remove('on')}
function abrir(id){document.getElementById(id).classList.add('on')}

/* ============ HOY ============ */
function totalesDia(key){
  const items=dias[key]||[];
  return items.reduce((a,i)=>({prot:a.prot+i.prot,kcal:a.kcal+i.kcal}),{prot:0,kcal:0});
}
function renderHoy(){
  document.getElementById('fechaHoy').textContent=fechaLarga(hoyKey());
  const t=totalesDia(hoyKey());
  const b=document.getElementById('balance');
  if(!metas){
    b.innerHTML=metro('Proteína',t.prot,null,'g','p')+metro('Calorías',t.kcal,null,'kcal','k')+
      '<p class="sinmeta">Sin metas definidas. <a onclick="verTab(\'ajus\')">Definirlas en Ajustes</a> para ver la diferencia diaria.</p>';
  }else{
    b.innerHTML=metro('Proteína',t.prot,metas.prot,'g','p')+metro('Calorías',t.kcal,metas.kcal,'kcal','k');
  }
  const lista=document.getElementById('listaHoy');
  const items=dias[hoyKey()]||[];
  if(!items.length){lista.innerHTML='<div class="vacio">Aún no registras nada hoy.<br>Usa ✨ IA, ⭐ frecuentes o ✏️ manual.</div>';return}
  lista.innerHTML=items.map(i=>`
    <div class="item">
      <div class="info"><div class="nombre">${esc(i.nombre)}</div><div class="hora">${i.hora}</div></div>
      <div class="macros"><span class="p">${n1(i.prot)} g</span><br><span class="k">${Math.round(i.kcal)} kcal</span></div>
      <div class="ops">
        <button title="Guardar en frecuentes" onclick="aFrecuente('${i.id}')">⭐</button>
        <button title="Eliminar" onclick="borrarItem('${i.id}')">🗑️</button>
      </div>
    </div>`).join('');
}
function metro(nom,val,meta,unidad,clase){
  let barra='',diff='';
  if(meta){
    const pct=Math.min(100,val/meta*100);
    const over=val>meta;
    barra=`<div class="barra"><div class="fill ${over?'over':clase}" style="width:${over?100:pct}%"></div></div>`;
    const d=meta-val;
    if(Math.abs(d)<(unidad==='g'?1:10)) diff=`<div class="diff ok">Meta cumplida ✓</div>`;
    else if(d>0) diff=`<div class="diff neutro">Faltan ${unidad==='g'?n1(d)+' g':Math.round(d)+' kcal'}</div>`;
    else diff=`<div class="diff over">Te pasaste ${unidad==='g'?n1(-d)+' g':Math.round(-d)+' kcal'}</div>`;
  }
  return `<div class="metro">
    <div class="fila"><span class="nombre">${nom}</span>
    <span class="num">${unidad==='g'?n1(val):Math.round(val)} <small>/ ${meta?(unidad==='g'?n1(meta):Math.round(meta)):'—'} ${unidad}</small></span></div>
    ${barra}${diff}</div>`;
}
function agregarItem(nombre,prot,kcal){
  const key=hoyKey();
  if(!dias[key])dias[key]=[];
  const h=new Date();
  dias[key].push({id:uid(),nombre,prot:+prot,kcal:+kcal,
    hora:String(h.getHours()).padStart(2,'0')+':'+String(h.getMinutes()).padStart(2,'0')});
  set(K.dias,dias);renderHoy();
}
function borrarItem(id){
  const key=hoyKey();
  dias[key]=(dias[key]||[]).filter(i=>i.id!==id);
  if(!dias[key].length)delete dias[key];
  set(K.dias,dias);renderHoy();
}
function aFrecuente(id){
  const it=(dias[hoyKey()]||[]).find(i=>i.id===id);
  if(!it)return;
  if(frec.some(f=>f.nombre.toLowerCase()===it.nombre.toLowerCase())){alert('Ya está en frecuentes');return}
  frec.push({id:uid(),nombre:it.nombre,prot:it.prot,kcal:it.kcal});
  set(K.frec,frec);alert('Guardado en frecuentes ⭐');
}
function esc(s){return s.replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}

/* ============ MANUAL ============ */
let manualEsFrec=false;
function abrirManual(soloFrec){
  manualEsFrec=!!soloFrec;
  document.getElementById('tituloManual').textContent=soloFrec?'Nuevo frecuente':'Ingreso manual';
  document.getElementById('mNombre').value='';document.getElementById('mProt').value='';document.getElementById('mKcal').value='';
  document.getElementById('mFrec').checked=!!soloFrec;
  document.getElementById('mErr').style.display='none';
  abrir('ovManual');
}
function guardarManual(){
  const nom=document.getElementById('mNombre').value.trim();
  const p=parseFloat(document.getElementById('mProt').value);
  const k=parseFloat(document.getElementById('mKcal').value);
  if(!nom||isNaN(p)||isNaN(k)){document.getElementById('mErr').style.display='block';return}
  if(document.getElementById('mFrec').checked && !frec.some(f=>f.nombre.toLowerCase()===nom.toLowerCase())){
    frec.push({id:uid(),nombre:nom,prot:p,kcal:k});set(K.frec,frec);
  }
  if(!manualEsFrec)agregarItem(nom,p,k);
  cerrar('ovManual');
  if(manualEsFrec)renderFrec();
}

/* ============ FRECUENTES ============ */
function renderFrec(){
  const l=document.getElementById('listaFrec');
  if(!frec.length){l.innerHTML='<div class="vacio">Sin frecuentes aún.<br>Crea uno abajo o guarda ⭐ cualquier comida de tu día.</div>';return}
  l.innerHTML=frec.map(f=>`
    <div class="freq">
      <div class="info" style="min-width:0">
        <div class="nombre" style="font-weight:600;font-size:.95rem">${esc(f.nombre)}</div>
        <div style="font-size:.82rem;color:var(--muted);font-variant-numeric:tabular-nums">
          <span style="color:var(--prot);font-weight:600">${n1(f.prot)} g</span> · <span style="color:var(--kcal);font-weight:600">${Math.round(f.kcal)} kcal</span>
        </div>
      </div>
      <button class="del" onclick="borrarFrec('${f.id}')">🗑️</button>
      <button class="add" onclick="usarFrec('${f.id}')">＋</button>
    </div>`).join('');
}
function usarFrec(id){
  const f=frec.find(x=>x.id===id);if(!f)return;
  agregarItem(f.nombre,f.prot,f.kcal);
  verTab('hoy');
}
function borrarFrec(id){
  if(!confirm('¿Eliminar este frecuente?'))return;
  frec=frec.filter(f=>f.id!==id);set(K.frec,frec);renderFrec();
}

/* ============ HISTORIAL ============ */
function renderHist(){
  const l=document.getElementById('listaHist');
  const keys=Object.keys(dias).sort().reverse();
  if(!keys.length){l.innerHTML='<div class="vacio">Todavía no hay días registrados.</div>';return}
  l.innerHTML=keys.map(k=>{
    const t=totalesDia(k);
    let chips='';
    if(metas){
      chips+=t.prot>=metas.prot?'<span class="chip ok">prot ✓</span>':'';
      chips+=t.kcal>metas.kcal?'<span class="chip over">+kcal</span>':'';
    }
    const filas=(dias[k]||[]).map(i=>`<div class="r"><span>${i.hora} · ${esc(i.nombre)}</span><span>${n1(i.prot)} g · ${Math.round(i.kcal)} kcal</span></div>`).join('');
    const difP=metas?` (${t.prot-metas.prot>=0?'+':''}${n1(t.prot-metas.prot)})`:'';
    const difK=metas?` (${t.kcal-metas.kcal>=0?'+':''}${Math.round(t.kcal-metas.kcal)})`:'';
    return `<div class="dia-hist" onclick="this.classList.toggle('abierto')">
      <div class="cab">
        <span class="f">${fechaLarga(k)}${chips}</span>
        <span class="tot"><span style="color:var(--prot);font-weight:600">${n1(t.prot)} g${difP}</span><br><span style="color:var(--kcal);font-weight:600">${Math.round(t.kcal)} kcal${difK}</span></span>
      </div>
      <div class="detalle">${filas}</div>
    </div>`;
  }).join('');
}

/* ============ METAS / CALCULADORA ============ */
function cargarAjustes(){
  if(metas){document.getElementById('metaKcal').value=metas.kcal;document.getElementById('metaProt').value=metas.prot}
  document.getElementById('apiKey').value=localStorage.getItem(K.key)||'';
}
function guardarMetas(){
  const kc=parseFloat(document.getElementById('metaKcal').value);
  const pr=parseFloat(document.getElementById('metaProt').value);
  if(isNaN(kc)||isNaN(pr)||kc<=0||pr<=0){alert('Ingresa ambas metas con valores válidos.');return}
  metas={kcal:Math.round(kc),prot:Math.round(pr)};set(K.metas,metas);
  alert('Metas guardadas ✓');verTab('hoy');
}
function abrirCalc(){document.getElementById('cErr').style.display='none';abrir('ovCalc')}
function calcular(){
  const s=document.getElementById('cSexo').value;
  const e=parseFloat(document.getElementById('cEdad').value);
  const p=parseFloat(document.getElementById('cPeso').value);
  const a=parseFloat(document.getElementById('cAlt').value);
  const act=parseFloat(document.getElementById('cAct').value);
  const obj=document.getElementById('cObj').value;
  if([e,p,a].some(isNaN)){document.getElementById('cErr').style.display='block';return}
  let bmr=10*p+6.25*a-5*e+(s==='m'?5:-161);
  let kcal=bmr*act;
  let gkg=1.4;
  if(obj==='bajar'){kcal*=0.8;gkg=1.8}
  if(obj==='subir'){kcal*=1.1;gkg=1.8}
  metas={kcal:Math.round(kcal/10)*10,prot:Math.round(p*gkg)};
  set(K.metas,metas);cerrar('ovCalc');
  alert(`Metas calculadas:\n${metas.kcal} kcal · ${metas.prot} g de proteína\n\nRecuerda: es una estimación, no indicación médica.`);
  verTab('hoy');
}

/* ============ IA ============ */
let iaItems=[];
let iaFotoB64=null; // base64 sin prefijo, jpeg redimensionado
function abrirIA(conFoto){
  document.getElementById('iaTexto').value='';
  document.getElementById('iaResultado').style.display='none';
  document.getElementById('iaErr').style.display='none';
  quitarFoto();
  abrir('ovIA');
  if(conFoto)document.getElementById('iaFoto').click();
}
function quitarFoto(){
  iaFotoB64=null;
  document.getElementById('iaPreviewBox').style.display='none';
  document.getElementById('iaFoto').value='';
}
function fotoElegida(inp){
  const f=inp.files[0];if(!f)return;
  const img=new Image();
  const url=URL.createObjectURL(f);
  img.onload=()=>{
    const MAX=1024;
    let w=img.width,h=img.height;
    if(w>MAX||h>MAX){const r=Math.min(MAX/w,MAX/h);w=Math.round(w*r);h=Math.round(h*r)}
    const c=document.createElement('canvas');c.width=w;c.height=h;
    c.getContext('2d').drawImage(img,0,0,w,h);
    const dataUrl=c.toDataURL('image/jpeg',0.8);
    iaFotoB64=dataUrl.split(',')[1];
    document.getElementById('iaPreview').src=dataUrl;
    document.getElementById('iaPreviewBox').style.display='block';
    URL.revokeObjectURL(url);
  };
  img.onerror=()=>{URL.revokeObjectURL(url);alert('No se pudo leer la imagen.')};
  img.src=url;
}
async function estimarIA(){
  const txt=document.getElementById('iaTexto').value.trim();
  const err=document.getElementById('iaErr');
  err.style.display='none';
  if(!txt&&!iaFotoB64){err.textContent='Toma una foto o describe lo que comiste.';err.style.display='block';return}
  const btn=document.getElementById('iaBtn');
  btn.disabled=true;btn.innerHTML='<span class="spin"></span>Estimando…';
  try{
    const key=localStorage.getItem(K.key)||'';
    const headers={'Content-Type':'application/json'};
    if(key){headers['x-api-key']=key;headers['anthropic-version']='2023-06-01';headers['anthropic-dangerous-direct-browser-access']='true'}
    const prompt=`Eres un nutricionista. Estima proteína (g) y calorías (kcal) de esta comida de una persona en Chile. Conoces platos chilenos (completo, empanada de pino, cazuela, pan marraqueta, palta, etc). Si no hay cantidades, asume porciones normales de adulto.${iaFotoB64?' Analiza la foto del plato; si hay texto, úsalo como contexto adicional sobre porciones e ingredientes.':''}
Responde SOLO con JSON válido, sin markdown ni texto extra, con este formato exacto:
{"items":[{"nombre":"...","proteina_g":0,"kcal":0}]}${txt?'\nComida: '+txt:''}`;
    const contenido=[];
    if(iaFotoB64)contenido.push({type:'image',source:{type:'base64',media_type:'image/jpeg',data:iaFotoB64}});
    contenido.push({type:'text',text:prompt});
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers,
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,messages:[{role:'user',content:contenido}]})
    });
    if(!r.ok)throw new Error('HTTP '+r.status);
    const data=await r.json();
    const texto=(data.content||[]).filter(c=>c.type==='text').map(c=>c.text).join('\n');
    const limpio=texto.replace(/```json|```/g,'').trim();
    const json=JSON.parse(limpio);
    if(!json.items||!json.items.length)throw new Error('sin items');
    iaItems=json.items.map(i=>({nombre:String(i.nombre),prot:+i.proteina_g||0,kcal:+i.kcal||0}));
    renderIA();
    document.getElementById('iaResultado').style.display='block';
  }catch(e){
    const key=localStorage.getItem(K.key)||'';
    err.textContent=key
      ?'No se pudo estimar ('+e.message+'). Revisa tu API key o intenta de nuevo.'
      :'No se pudo estimar. Fuera de Claude necesitas guardar tu API key en Ajustes. Mientras tanto, usa ingreso manual o frecuentes.';
    err.style.display='block';
  }
  btn.disabled=false;btn.textContent='Estimar';
}
function renderIA(){
  document.getElementById('iaItems').innerHTML=iaItems.map((it,idx)=>`
    <div class="ia-item">
      <input type="text" value="${esc(it.nombre)}" onchange="iaItems[${idx}].nombre=this.value">
      <input type="number" value="${n1(it.prot)}" inputmode="decimal" onchange="iaItems[${idx}].prot=+this.value||0">
      <input type="number" value="${Math.round(it.kcal)}" inputmode="decimal" onchange="iaItems[${idx}].kcal=+this.value||0">
      <button onclick="iaItems.splice(${idx},1);renderIA()">✕</button>
    </div>`).join('');
}
function guardarIA(){
  iaItems.forEach(it=>{if(it.nombre.trim())agregarItem(it.nombre.trim(),it.prot,it.kcal)});
  iaItems=[];quitarFoto();cerrar('ovIA');
}

/* ============ RESPALDO ============ */
function exportar(){
  const blob=new Blob([JSON.stringify({dias,metas,frec},null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='mi-balance-respaldo-'+hoyKey()+'.json';
  a.click();
}
function importar(inp){
  const f=inp.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=()=>{try{
    const d=JSON.parse(r.result);
    if(d.dias)dias=d.dias; if(d.metas)metas=d.metas; if(d.frec)frec=d.frec;
    set(K.dias,dias);set(K.metas,metas);set(K.frec,frec);
    alert('Respaldo restaurado ✓');verTab('hoy');
  }catch(e){alert('Archivo inválido.')}};
  r.readAsText(f);
}
function guardarKey(){
  localStorage.setItem(K.key,document.getElementById('apiKey').value.trim());
  alert('Key guardada en este navegador ✓');
}
function borrarTodo(){
  if(!confirm('Esto borra TODO: días, metas y frecuentes. ¿Segura?'))return;
  if(!confirm('Última confirmación. No se puede deshacer.'))return;
  localStorage.removeItem(K.dias);localStorage.removeItem(K.metas);localStorage.removeItem(K.frec);
  dias={};metas=null;frec=[];verTab('hoy');
}

/* cerrar modal tocando fuera */
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('on')}));

renderHoy();
</script>
</body>
</html>
